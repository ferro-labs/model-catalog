# Ferro Model Catalog — Environment Variables
# Copy this file to .env and fill in values as needed.

# ── Scraper API Keys (optional, listing-only — no completions, no spend) ──
# Only needed if running provider-specific scrapers (not required for oracle scrapers)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# TOGETHER_API_KEY=...
# FIREWORKS_API_KEY=...
# MISTRAL_API_KEY=...
# COHERE_API_KEY=...
# DEEPSEEK_API_KEY=...
# XAI_API_KEY=...

# ── Testing ──
# Path to a catalog.json file for the round-trip regression test.
# Defaults to dist/catalog.json if not set.
# CATALOG_TEST_SOURCE=/path/to/catalog.json
